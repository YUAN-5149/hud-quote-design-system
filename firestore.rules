rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 從登入者的內部帳號 (<phone>@hud-quote.app) 取出手機號
    function callerPhone() {
      return request.auth.token.email.split('@')[0];
    }
    // 必須已登入且仍在白名單內 — 從白名單移除即失去所有存取權
    function isMember() {
      return request.auth != null
        && exists(/databases/$(database)/documents/whitelist/$(callerPhone()));
    }
    function isAdmin() {
      return isMember()
        && get(/databases/$(database)/documents/whitelist/$(callerPhone())).data.role == '管理';
    }

    // 白名單：讀取開放（登入前需查詢名單）；寫入僅限管理員
    match /whitelist/{phone} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 公司設定：成員可讀（報價單抬頭），僅管理員可改
    match /settings/{docId} {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    // 業務資料：白名單成員可讀寫
    match /{col}/{docId} {
      allow read, write: if col in ['cases', 'invoices', 'quotes', 'materials', 'moves']
        && isMember();
    }
  }
}
